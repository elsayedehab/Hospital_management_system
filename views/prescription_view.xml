<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_patient_prescription_tree" model="ir.ui.view">
            <field name="name">patient.prescription.tree</field>
            <field name="model">patient.prescription</field>
            <field name="arch" type="xml">
                <tree string="Prescriptions">
                    <field name="prescription_serial" />
                    <field name="prescription_date" />
                    <field name="appointment_id" />
                    <field name="patient_id" />
                </tree>
            </field>
        </record>

        <record id="view_patient_prescription_form" model="ir.ui.view">
            <field name="name">patient.prescription.form</field>
            <field name="model">patient.prescription</field>
            <field name="arch" type="xml">
                <form string="Patient Prescription">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="prescription_serial" readonly="1" />
                            </h1>
                        </div>
                        <group>
                            <group string="Main Information">
                                <field name="prescription_date" />
                                <field name="appointment_id" options="{'no_create': True}" />
                                <field name="appointment_id_name" />
                            </group>
                            <group string="Patient Details">
                                <field name="patient_id" readonly="1" force_save="1" />
                            </group>
                        </group>

                        <notebook>
                            <page string="Medicines" name="medicine_lines">
                                <field name="patient_line_id">
                                    <tree editable="bottom">
                                        <field name="medicine_trade_name"
                                            placeholder="Panadol" />
                                        <field name="therapeutic_regimen"
                                            placeholder="description" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_patient_prescription" model="ir.actions.act_window">
            <field name="name">Prescriptions</field>
            <field name="res_model">patient.prescription</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create the first prescription for your patient!
                </p>
            </field>
        </record>
    </data>
</odoo>