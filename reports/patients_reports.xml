<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_prescription" model="ir.actions.report">
        <field name="name">Medical Prescription</field>
        <field name="model">patient.prescription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.report_prescription_template</field>
        <field name="report_file">hospital_management.report_prescription_template</field>
        <field name="print_report_name">'Prescription_%s' % (object.prescription_serial)</field>
        <field name="binding_model_id" ref="model_patient_prescription" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_prescription_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page"
                        style="direction: ltr; text-align: left; font-family: sans-serif;">

                        <div class="row mt-4"
                            style="border-bottom: 2px solid #004d40; padding-bottom: 10px;">

                            <div class="col-6" style="text-align: left !important;">
                                <div style="margin-bottom: 8px;">
                                    <strong style="color: #004d40;">Patient Name: </strong>
                                    <span t-field="o.patient_id.name" />
                                </div>
                                <div>
                                    <strong style="color: #004d40;">Appointment Date: </strong>
                                    <span t-field="o.appointment_id.booking_date"
                                        t-options='{"widget": "date"}' />
                                </div>
                            </div>

                            <div class="col-6" style="text-align: right !important;">
                                <div style="margin-bottom: 8px;">
                                    <strong style="color: #004d40;">Prescription No: </strong>
                                    <span t-field="o.prescription_serial" />
                                </div>
                                <div>
                                    <strong style="color: #004d40;">Date: </strong>
                                    <span t-field="o.prescription_date"
                                        t-options='{"widget": "date"}' />
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12">
                                <h1
                                    style="color: #004d40; font-style: italic; font-weight: bold; font-size: 50px; margin-left: 10px;">
                                    Rx</h1>
                            </div>
                        </div>

                        <table class="table table-sm mt-3"
                            style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr
                                    style="background-color: #f2f2f2; border-bottom: 2px solid #dee2e6;">
                                    <th style="padding: 12px; width: 40%; text-align: left;">Medicine
                                        (Trade Name)</th>
                                    <th style="padding: 12px; width: 60%; text-align: left;">Therapeutic
                                        Regimen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.patient_line_id" t-as="line">
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td style="padding: 15px;">
                                            <strong t-field="line.medicine_trade_name"
                                                style="font-size: 16px;" />
                                        </td>
                                        <td style="padding: 15px; color: #555;">
                                            <span t-field="line.therapeutic_regimen" />
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row" style="margin-top: 100px;">
                            <div class="col-8"></div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #333; padding-top: 10px;">
                                    <strong>Doctor's Signature</strong>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>