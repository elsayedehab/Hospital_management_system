<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_prescription" model="ir.actions.report">
        <field name="name">Patient Prescription</field>
        <field name="model">patient.prescription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.report_prescription_template</field>
        <field name="report_file">hospital_management.report_prescription_template</field>
        <field name="binding_model_id" ref="model_patient_prescription" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_prescription_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure" />
                        <h2 class="text-center">Medical Prescription</h2>
                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Serial: </strong>
                                <span t-field="o.prescription_serial" />
                                <br />
                                <strong>Date: </strong>
                                <span t-field="o.prescription_date" />
                            </div>
                            <div class="col-6 text-end">
                                <strong>Patient: </strong>
                                <span t-field="o.patient_id.name" />
                                <br />
                                <strong>Appointment: </strong>
                                <span t-field="o.appointment_id_name" />
                            </div>
                        </div>

                        <br />
                        <table class="table table-bordered" style="width: 100%;">
                            <thead>
                                <tr style="background-color: #f2f2f2;">
                                    <th>Medicine Trade Name</th>
                                    <th>Therapeutic Regimen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.patient_line_id" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-field="line.medicine_trade_name" />
                                        </td>
                                        <td>
                                            <span t-field="line.therapeutic_regimen" />
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>