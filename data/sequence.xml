<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_patient_prescription" model="ir.sequence">
            <field name="name">Patient Prescription Sequence</field>
            <field name="code">patient.appointment.prescription.sequence</field>
            <field name="prefix">PRES/%(range_year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False" />
        </record>

        <record id="seq_hospital_appointment" model="ir.sequence">
            <field name="name">Hospital Appointment Sequence</field>
            <field name="code">hospital.appointment.sequence</field>
            <field name="prefix">APT/%(range_year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False" />
        </record>
    </data>
</odoo>